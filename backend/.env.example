# ──────────────────────────────────────────────
# CONFIGURACIÓN DEL COMPARADOR DIAN vs SIESA
# ──────────────────────────────────────────────
# Copia este archivo como .env y llena los valores

# API Key de Groq (gratuita en console.groq.com)
# Si no la configuras, el sistema generará el informe de forma local sin IA
GROQ_API_KEY=tu_api_key_de_groq_aqui

# Puerto del servidor (por defecto 8000)
PORT=8000
